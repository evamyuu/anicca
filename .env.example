# ─────────────────────────────────────────────────────────────────────────────
# Anicca — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── Database (PostgreSQL 16 + pgvector) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://anicca:anicca@localhost:5432/anicca_dev

# ── Cache (Redis 7) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── WhatsApp — Whatsmiau Cloud ────────────────────────────────────────────────
# Dashboard: https://whatsmiau.dev/dashboard
WHATSMIAU_TOKEN=your_whatsmiau_bearer_token
WHATSMIAU_INSTANCE_ID=your_instance_id
WHATSMIAU_WEBHOOK_SECRET=your_hmac_sha256_secret
WHATSMIAU_API_BASE=https://api.whatsmiau.dev

# ── AI — Anthropic Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_api_key

# ── AWS (S3 + Textract) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=sa-east-1
AWS_S3_BUCKET=anicca-documents-dev

# ── Neo4j (Phase 5 — Oncology Knowledge Graph) ────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── LGPD ──────────────────────────────────────────────────────────────────────
PSEUDONYMIZATION_SALT=change-me-in-production-use-openssl-rand-hex-32

# ── Expo Mobile App ───────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000
