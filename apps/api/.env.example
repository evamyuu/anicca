# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/anicca

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_RPM=60

# ── API ───────────────────────────────────────────────────────────────────────
API_PUBLIC_URL=https://api.anicca.app
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8081", "https://anicca.app"]

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_dev_key
JWT_REFRESH_SECRET=super_secret_refresh_dev_key

# ── AI / LLM ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ── WhatsApp (Whatsmiau) ──────────────────────────────────────────────────────
WHATSMIAU_URL=http://localhost:3333
WHATSMIAU_TOKEN=dev_token

# ── Push Notifications ───────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=YOUR_EXPO_TOKEN_HERE

# ── AWS Textract ──────────────────────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_S3_BUCKET=anicca-med-docs
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
