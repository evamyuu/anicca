{
  "extends": "../../packages/config/tsconfig.react-native.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@anicca/types": [
        "../../packages/types/src/index.ts"
      ],
      "@anicca/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@anicca/i18n": [
        "../../packages/i18n/src/index.ts"
      ],
      "@anicca/ui": [
        "../../packages/ui/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
